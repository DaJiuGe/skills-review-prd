{
  "name": "review-prd-skill",
  "version": "1.0.0",
  "description": "PRD EventStorming 评审 Skill：多轮 LLM 结构化抽取 + 报告落盘",
  "type": "module",
  "main": "index.js",
  "bin": {
    "review-prd": "index.js"
  },
  "scripts": {
    "review": "node index.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  },
  "keywords": [
    "ddd",
    "event-storming",
    "prd-review",
    "llm"
  ],
  "files": [
    "index.js",
    "lib/",
    "skills/",
    "fixtures/",
    "assets/",
    "SKILL.md",
    "skill.json",
    "REFERENCE.md",
    "EXAMPLES.md",
    "README.md",
    "README.zh_CN.md",
    "LICENSE"
  ],
  "license": "MIT",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "tests"
  },
  "author": ""
}
